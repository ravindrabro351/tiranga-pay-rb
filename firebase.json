{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": [
    {
      "target": "user",
      "public": "user-app",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ]
    },
    {
      "target": "admin",
      "public": "admin-panel",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ]
    }
  ]
}